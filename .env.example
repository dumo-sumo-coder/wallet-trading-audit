ENV=dev

# Required for Solana ingestion unless SOLANA_RPC_URL is set explicitly.
HELIUS_API_KEY=your_helius_api_key_here

# Optional explicit Solana RPC override. If set, this takes precedence over
# HELIUS_API_KEY-derived Helius mainnet RPC construction.
SOLANA_RPC_URL=

# Reserved for future direct EVM RPC ingestion. The current BNB/EVM raw
# ingestion flow uses Etherscan V2 instead of a direct RPC URL.
EVM_RPC_URL=

# Required for the current BNB/EVM ingestion flow.
ETHERSCAN_API_KEY=your_etherscan_api_key_here
